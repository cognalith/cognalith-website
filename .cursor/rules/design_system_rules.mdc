## 2. Component Library

### Location

```
cognalith-website/
├── components/
│   ├── ui/              # Reusable primitives
│   │   ├── Button.tsx   # Primary, secondary, outline variants
│   │   ├── Card.tsx     # Animated card wrapper
│   │   └── Container.tsx # Max-width layout wrapper
│   ├── sections/        # Page sections
│   │   ├── Hero.tsx
│   │   ├── HeroEnhanced.tsx
│   │   ├── AIAgents.tsx
│   │   ├── Services.tsx
│   │   └── ...
│   └── animations/      # Animation components
│       ├── NeuralNetwork.tsx
│       ├── ParticleField.tsx
│       └── FloatingMonolith.tsx
```

### Component Architecture

All components follow this pattern:

```tsx
"use client"; // Required for framer-motion

import { motion } from "framer-motion";

interface ComponentProps {
  children: React.ReactNode;
  className?: string;
  // variant props
}

export default function Component({ children, className = "" }: ComponentProps) {
  return (
    <motion.div className={`base-styles ${className}`}>
      {children}
    </motion.div>
  );
}
```

### Core UI Components

#### Button

```tsx
import Button from "@/components/ui/Button";

// Variants
<Button variant="primary">CTA</Button>    // Gradient cyan-purple
<Button variant="secondary">Action</Button> // Dark card background
